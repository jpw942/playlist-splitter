generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum JobStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

model Job {
  id             String    @id @default(cuid())
  createdAt      DateTime  @default(now())
  userId         String
  playlistId     String
  playlistName   String
  status         JobStatus @default(PENDING)
  tracks         Track[]
}

model Track {
  id         String   @id @default(cuid())
  jobId      String
  job        Job      @relation(fields: [jobId], references: [id])
  spotifyId  String
  name       String
  artist     String
  previewUrl String?
  embedding  Json?
  clusterId  Int?
  createdAt  DateTime @default(now())
}